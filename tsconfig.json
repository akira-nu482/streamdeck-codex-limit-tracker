{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "ESNext.Decorators"],
    "strict": true,
    "noEmitOnError": true,
    "sourceMap": true,
    "esModuleInterop": true,
    "useDefineForClassFields": false,
    "types": ["node"]
  },
  "include": ["src/**/*.ts"]
}
